rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - createdAt: string (optional)
    //
    // Collection: audits
    // Document ID: {auditId}
    // Fields:
    //   - uid: string (required)
    //   - formData: map (required)
    //   - result: map (required)
    //   - createdAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidAudit(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.formData is map &&
             data.result is map &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /audits/{auditId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAudit(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
